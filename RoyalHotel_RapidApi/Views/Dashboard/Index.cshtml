@model List<RoyalHotel_RapidApi.Models.LocationViewModel>
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Royal Hotel | Yönetim Paneli</title>
    <link href="https://fonts.googleapis.com/css2?family=Spline+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#36e27b",
                        "background-dark": "#0a120e",
                        "card-dark": "#14251c",
                        "accent-gold": "#d4af37"
                    }
                }
            }
        }
    </script>
    <style>
        .glass-effect {
            background: rgba(20, 37, 28, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .custom-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #36e27b;
            border-radius: 10px;
        }
    </style>
</head>
<body class="bg-background-dark font-display antialiased text-white">
    <div class="min-h-screen w-full max-w-6xl mx-auto p-4 md:p-8">

        <header class="flex flex-wrap items-center justify-between gap-6 mb-10">
            <div class="flex items-center gap-4">
                <div class="size-14 rounded-2xl bg-gradient-to-br from-primary to-emerald-700 flex items-center justify-center shadow-lg shadow-primary/20">
                    <span class="material-symbols-outlined text-black text-3xl font-bold">hotel</span>
                </div>
                <div>
                    <h1 class="text-2xl font-bold tracking-tight">Royal Hotel Dashboard</h1>
                    <p class="text-sm text-slate-400">Hoş geldin Münevver, Aydın lokasyonu için günlük rapor hazır.</p>
                </div>
            </div>

            <div class="flex items-center gap-6 bg-card-dark/50 p-3 rounded-2xl border border-white/5 shadow-xl">
                <div class="flex items-center gap-3 px-4 border-r border-white/10">
                    <span class="material-symbols-outlined text-yellow-400">
                        @* Duruma göre ikon değişimi *@
                        @(ViewBag.status?.ToString().ToLower().Contains("bulut") == true ? "cloud" : "wb_sunny")
                    </span>
                    <span class="text-xl font-bold">@ViewBag.temp°</span>
                </div>
                <div class="flex items-center gap-4 px-4">
                    <div class="text-center">
                        <p class="text-[10px] uppercase text-slate-400">Dolar</p>
                        <p class="font-bold text-primary">@ViewBag.usd₺</p>
                    </div>
                    <div class="text-center">
                        <p class="text-[10px] uppercase text-slate-400">Euro</p>
                        <p class="font-bold text-blue-400">@ViewBag.eur₺</p>
                    </div>
                </div>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

            <section class="lg:col-span-7 flex flex-col gap-6">
                <div class="relative overflow-hidden rounded-[2.5rem] glass-effect p-8 min-h-[480px] flex flex-col justify-between border-t border-white/10 shadow-2xl">
                    <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 blur-[100px] -mr-20 -mt-20"></div>

                    <div>
                        <div class="flex items-center gap-3 mb-6">
                            <span class="px-3 py-1 rounded-full bg-primary/20 text-primary text-[10px] font-bold uppercase tracking-widest">Özel Seçki</span>
                            <span class="flex items-center gap-1 text-[10px] text-slate-400 uppercase tracking-widest">
                                <span class="material-symbols-outlined text-sm text-primary">auto_awesome</span> Yapay Zeka Önerisi
                            </span>
                        </div>
                        <h2 class="text-4xl font-extrabold mb-4 leading-tight">Şefin Günlük <br /><span class="text-primary">Gurme Tavsiyesi</span></h2>
                        <p class="text-xl text-slate-200 italic font-serif leading-relaxed pr-10">
                            "@ViewBag.chefRecommend"
                        </p>
                    </div>

                    <div class="grid grid-cols-3 gap-4 mt-8 pt-8 border-t border-white/5">
                        <div class="flex flex-col gap-1">
                            <span class="text-[10px] text-slate-400 uppercase">Hazırlık</span>
                            <span class="text-sm font-bold uppercase">45 Dakika</span>
                        </div>
                        <div class="flex flex-col gap-1">
                            <span class="text-[10px] text-slate-400 uppercase">Eşlikçi</span>                 
                            <span class="text-sm font-bold uppercase text-accent-gold">Yayık Ayranı</span>
                        </div>
                        <div class="flex flex-col gap-1">
                            <span class="text-[10px] text-slate-400 uppercase">İçerik</span>
                            <span class="text-sm font-bold uppercase">Yerel Ürünler</span>
                        </div>
                    </div>

                    <button class="mt-8 w-full bg-primary hover:bg-emerald-400 text-black font-bold py-4 rounded-2xl transition-all transform hover:scale-[1.02] flex items-center justify-center gap-3 shadow-lg shadow-primary/20">
                        <span class="material-symbols-outlined">restaurant_menu</span>
                        Mutfak Ekibine Bilgi Gönder
                    </button>
                </div>
            </section>

            <section class="lg:col-span-5 flex flex-col gap-6">
                <div class="flex items-center justify-between px-2">
                    <h3 class="text-lg font-bold flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">explore</span> Keşif Noktaları
                    </h3>
                    <span class="text-xs text-slate-400 uppercase tracking-widest border-b border-primary/30 pb-1 cursor-pointer hover:text-primary transition-colors">Aydın Rehberi</span>
                </div>

                <div class="flex flex-col gap-4 custom-scrollbar overflow-y-auto max-h-[520px] pr-2">
                    @if (Model != null)
                    {
                        @foreach (var item in Model)
                        {
                            <div class="group relative flex items-center gap-4 bg-card-dark/40 hover:bg-card-dark/80 p-4 rounded-[1.5rem] border border-white/5 transition-all cursor-pointer shadow-sm">
                                <div class="size-16 rounded-xl bg-gradient-to-br from-white/10 to-transparent flex items-center justify-center shrink-0 border border-white/10">
                                    <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform">location_on</span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <h4 class="font-bold text-sm mb-1 truncate">@item.Name</h4>
                                    <p class="text-xs text-slate-400 line-clamp-2 leading-relaxed">@item.Description</p>
                                    <div class="flex items-center gap-2 mt-2">
                                        <span class="text-[9px] bg-primary/10 px-2 py-0.5 rounded text-primary border border-primary/10 uppercase tracking-tighter">
                                            Hemen Keşfet
                                        </span>
                                        <span class="text-[9px] bg-accent-gold/10 px-2 py-0.5 rounded text-accent-gold border border-accent-gold/10 uppercase tracking-tighter">
                                            Aydın Rehberi
                                        </span>
                                    </div>
                                </div>
                                <span class="material-symbols-outlined text-slate-500 group-hover:text-primary transition-colors">arrow_forward_ios</span>
                            </div>
                        }
                    }
                </div>

          
                <div class="mt-auto grid grid-cols-2 gap-3">

                    <!-- KRİPTO PARA -->
                    <div class="bg-card-dark/40 p-4 rounded-2xl border border-white/5">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-[10px] font-bold flex items-center gap-2 uppercase tracking-widest text-slate-300">
                                <span class="size-2 rounded-full bg-primary inline-block"></span>
                                Kripto Para
                            </h3>
                            <span class="text-[8px] text-slate-500 uppercase tracking-widest">USD</span>
                        </div>
                        <div class="flex flex-col gap-2">
                            <!-- BTC -->
                            <div class="flex items-center justify-between bg-card-dark/60 rounded-xl px-3 py-2 border border-white/5">
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-orange-500/10 border border-orange-500/20 flex items-center justify-center text-orange-400 font-bold text-[10px]">₿</div>
                                    <span class="text-[10px] text-slate-400 uppercase">BTC</span>
                                </div>
                                <span class="text-xs font-bold text-white">$@ViewBag.btc</span>
                            </div>
                            <!-- ETH -->
                            <div class="flex items-center justify-between bg-card-dark/60 rounded-xl px-3 py-2 border border-white/5">
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400 font-bold text-[10px]">Ξ</div>
                                    <span class="text-[10px] text-slate-400 uppercase">ETH</span>
                                </div>
                                <span class="text-xs font-bold text-white">$@ViewBag.eth</span>
                            </div>
                            <!-- BNB -->
                            <div class="flex items-center justify-between bg-card-dark/60 rounded-xl px-3 py-2 border border-white/5">
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center text-yellow-400 font-bold text-[10px]">B</div>
                                    <span class="text-[10px] text-slate-400 uppercase">BNB</span>
                                </div>
                                <span class="text-xs font-bold text-white">$@ViewBag.bnb</span>
                            </div>
                        </div>
                    </div>

                    <!-- AKARYAKIT -->
                    <div class="bg-card-dark/40 p-4 rounded-2xl border border-white/5 border-l-2 border-l-orange-500/60">
                        <div class="flex items-center justify-between mb-3">
                            <h3 class="text-[10px] font-bold flex items-center gap-2 uppercase tracking-widest text-slate-300">
                                <span class="material-symbols-outlined text-orange-400 text-sm">local_gas_station</span>
                                Akaryakıt
                            </h3>
                            <span class="text-[8px] text-slate-500 uppercase tracking-widest">Aydın</span>
                        </div>
                        <div class="flex flex-col gap-2">
                            <!-- Benzin -->
                            <div class="flex items-center justify-between bg-card-dark/60 rounded-xl px-3 py-2 border border-white/5">
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-green-500/10 border border-green-500/20 flex items-center justify-center">
                                        <span class="text-[8px] font-bold text-green-400">95</span>
                                    </div>
                                    <span class="text-[10px] text-slate-400 uppercase">Benzin</span>
                                </div>
                                <span class="text-xs font-bold text-white">@ViewBag.benzin ₺</span>
                            </div>
                            <!-- Motorin -->
                            <div class="flex items-center justify-between bg-card-dark/60 rounded-xl px-3 py-2 border border-white/5">
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-blue-500/10 border border-blue-500/20 flex items-center justify-center">
                                        <span class="text-[8px] font-bold text-blue-400">DZ</span>
                                    </div>
                                    <span class="text-[10px] text-slate-400 uppercase">Motorin</span>
                                </div>
                                <span class="text-xs font-bold text-white">@ViewBag.motorin ₺</span>
                            </div>
                            <!-- LPG -->
                            <div class="flex items-center justify-between bg-card-dark/60 rounded-xl px-3 py-2 border border-white/5">
                                <div class="flex items-center gap-2">
                                    <div class="size-6 rounded-full bg-purple-500/10 border border-purple-500/20 flex items-center justify-center">
                                        <span class="text-[8px] font-bold text-purple-400">LP</span>
                                    </div>
                                    <span class="text-[10px] text-slate-400 uppercase">LPG</span>
                                </div>
                                <span class="text-xs font-bold text-white">@ViewBag.lpg ₺</span>
                            </div>
                        </div>
                    </div>

                </div>
            </section>
        </div>

        <footer class="mt-16 pt-8 border-t border-white/5 flex justify-between items-center text-[10px] text-slate-500 uppercase tracking-[0.2em]">
            <span>Royal Hotel Group © 2026</span>
            <div class="flex gap-6">
                <span>Gizlilik Politikası</span>
                <span>Sistem Durumu</span>
            </div>
        </footer>
    </div>
</body>
</html>